# InfiniteX WAF — Environment Variables
# Copy to /etc/infinitex/infinitex.env on your EC2 instance

# Runtime
NODE_ENV=production

# WAF server port (Nginx proxies 80 → this port)
INFINITEX_PORT=3000

# Your backend application URL (what the WAF proxies traffic to)
BACKEND_URL=http://localhost:8080

# Path to WAF rule config JSON
INFINITEX_CONFIG=/etc/infinitex/infinitex-config.json

# Log directory
LOG_DIR=/var/log/infinitex
